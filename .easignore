**/.expo/
**/dist/
dms-frontend/build/
**/web-build/
**/.next/
**/.verification/
**/.eas-inspect-archive/
**/__pycache__/
**/*.pyc
**/*.tsbuildinfo
**/.env
**/.env.*
!**/.env.example
!**/.env.*.example
**/*.ipa
**/*.apk
**/*.log
