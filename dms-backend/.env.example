PORT=5000
NODE_ENV=development

MONGODB_URI=mongodb://localhost:27017/dms_db

JWT_SECRET=replace-with-a-strong-secret
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN_DAYS=30
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_MAX_FAILED_LOGIN_ATTEMPTS=5
AUTH_LOGIN_LOCK_MINUTES=15

CORS_ORIGIN=http://localhost:3000,http://localhost:8082
SOCKET_CORS_ORIGIN=http://localhost:3000,http://localhost:8082

CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

VNPAY_TMN_CODE=your-vnpay-sandbox-tmn-code
VNPAY_HASH_SECRET=your-vnpay-sandbox-hash-secret
VNPAY_PAYMENT_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
BACKEND_PUBLIC_URL=http://localhost:5000
VNPAY_RETURN_URL=http://localhost:5000/orders/vnpay/return
